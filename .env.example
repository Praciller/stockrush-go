APP_ENV=development
HTTP_PORT=8080
DATABASE_URL=postgres://stockrush:stockrush@localhost:5432/stockrush?sslmode=disable
RESERVATION_TTL=2m
WORKER_BATCH_SIZE=50
WORKER_POLL_INTERVAL=1s
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_BURST=40
